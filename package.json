{
	"name": "ocarina",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:host": "vite --host",
		"build": "npm run typecheck && vite build",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
		"postbuild": "copy CNAME dist",
		"lint": "eslint . --report-unused-disable-directives",
		"preview": "vite preview",
		"preview:host": "vite preview --host",
		"format": "prettier --write .",
		"deploy": "npm run build && gh-pages --dist ./dist --message \"github pages commit\" --no-history"
	},
	"dependencies": {
		"@react-spring/web": "^10.1.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@eslint/js": "^9.16.0",
		"@types/color": "^3.0.3",
		"@types/node": "^20.6.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"clsx": "^2.0.0",
		"color": "^4.2.3",
		"eslint": "^9.16.0",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.16",
		"gh-pages": "^6.0.0",
		"globals": "^15.13.0",
		"no-darkreader": "^1.0.3",
		"prettier": "^3.8.4",
		"sass": "^1.68.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.18.0",
		"vite": "^8.0.16",
		"vite-plugin-minify": "^3.0.0",
		"vite-plugin-svgr": "^5.2.0"
	}
}
