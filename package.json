{
	"name": "ocarina",
	"private": true,
	"version": "0.0.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:host": "vite --host",
		"build": "npm run typecheck && vite build",
		"typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
		"postbuild": "copy CNAME dist",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0",
		"preview": "vite preview",
		"preview:host": "vite preview --host",
		"format": "prettier --write .",
		"deploy": "npm run build && gh-pages --dist ./dist --message \"github pages commit\" --no-history",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@react-spring/web": "^10.1.1",
		"clsx": "^2.0.0",
		"color": "^4.2.3",
		"no-darkreader": "^1.0.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^9.16.0",
		"@playwright/test": "^1.61.0",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-mcp": "^0.6.0",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/react-vite": "^10.4.6",
		"@tailwindcss/vite": "^4.3.1",
		"@types/color": "^3.0.3",
		"@types/node": "^20.6.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"eslint": "^9.16.0",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-react-refresh": "^0.4.16",
		"gh-pages": "^6.0.0",
		"globals": "^15.13.0",
		"playwright": "^1.61.0",
		"prettier": "^3.8.4",
		"prettier-plugin-organize-imports": "^4.3.0",
		"storybook": "^10.4.6",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.18.0",
		"vite": "^8.0.16",
		"vite-plugin-minify": "^3.0.0",
		"vite-plugin-svgr": "^5.2.0",
		"vitest": "^4.1.9"
	}
